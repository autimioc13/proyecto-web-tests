# ========== SENDGRID EMAIL SERVICE ==========
# SendGrid API key for transactional emails
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here

# Email address to send from (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=compliance@quizlab.com

# ========== DATABASE (PostgreSQL) ==========
# Connection string format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ========== ENCRYPTION (AES-256) ==========
# Base64-encoded 256-bit encryption key
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=base64_encoded_256bit_key_here

# Base64-encoded 128-bit initialization vector
# Generate with: openssl rand -base64 16
ENCRYPTION_IV=base64_encoded_128bit_iv_here

# ========== ANTHROPIC & AI ==========
# Claude API key for AI features
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ========== ADMIN & SECURITY ==========
# Admin panel password (must be changed in production)
ADMIN_PASSWORD=change_me_in_production

# ========== ANALYTICS & URLS ==========
# Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G_XXXXXXXXXX

# Application base URL (used for links, redirects, etc.)
NEXT_PUBLIC_BASE_URL=https://quizlab.com

# ========== NODE ENVIRONMENT ==========
# Supported values: development, production, test
NODE_ENV=development
