# ========== SENDGRID EMAIL SERVICE ==========
# SendGrid API key for transactional emails
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here

# Email address to send from (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=compliance@quizlab.com

# ========== SUPABASE ==========
# Supabase project URL
# Get from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your_project.supabase.co

# Supabase anon public key (safe for browser)
# Get from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (KEEP SECRET - server-side only)
# Get from: https://app.supabase.com → Settings → API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ========== DATABASE (PostgreSQL) ==========
# Connection string format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ========== ENCRYPTION (AES-256) ==========
# Base64-encoded 256-bit encryption key
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=base64_encoded_256bit_key_here

# Base64-encoded 128-bit initialization vector
# Generate with: openssl rand -base64 16
ENCRYPTION_IV=base64_encoded_128bit_iv_here

# ========== ANTHROPIC & AI ==========
# Claude API key for AI features
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ========== ADMIN & SECURITY ==========
# Admin panel password (must be changed in production)
ADMIN_PASSWORD=change_me_in_production

# ========== ANALYTICS & URLS ==========
# Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G_XXXXXXXXXX

# Application base URL (used for links, redirects, etc.)
NEXT_PUBLIC_BASE_URL=https://quizlab.com

# ========== STRIPE PAYMENT INTEGRATION ==========
# Stripe API keys for payment processing
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret for webhook signature verification
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ========== PADDLE (MERCHANT OF RECORD) — ACTIVE PAYMENT PROVIDER ==========
# Paddle is the active provider (global, multi-currency incl. USD/EUR/COP,
# handles tax/VAT). Get values from https://vendors.paddle.com
#
# Environment: "sandbox" while testing, "production" when live
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Client-side token (Paddle > Developer Tools > Authentication > Client-side tokens)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxx
# Server-side API key (KEEP SECRET) — used by the webhook handler / SDK
PADDLE_API_KEY=pdl_sdbx_apikey_xxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret (Paddle > Developer Tools > Notifications > your destination)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxxxxxxxxxxx
# OPTIONAL: map internal product ids to Paddle price ids as JSON, e.g.
# NEXT_PUBLIC_PADDLE_PRICE_IDS={"basic-certificate":"pri_01...","premium-certificate":"pri_02..."}
NEXT_PUBLIC_PADDLE_PRICE_IDS=

# ========== NODE ENVIRONMENT ==========
# Supported values: development, production, test
NODE_ENV=development
